{
  "name": "house-brain-sim",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently \"npm --workspace server run dev\" \"npm --workspace web run dev\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "db:apply": "npm --workspace server run db:apply",
    "db:seed": "npm --workspace server run db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}